# AI Provider API Keys
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Admin Configuration
# ⚠️ CHANGE THIS IN PRODUCTION!
ADMIN_PASSWORD=your_secure_admin_password_here

# Vector Database Configuration
# Switch between 'chromadb' (local) and 'pinecone' (cloud)
VECTOR_DB_PROVIDER=pinecone

# ChromaDB (local development only)
CHROMA_PERSIST_DIR=./chroma_db

# Pinecone (cloud deployment - REQUIRED for production)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=esp-loyalty-docs1
PINECONE_ENVIRONMENT=us-east-1

# Analytics Database Configuration
# Switch between 'sqlite' (local) and 'postgres' (cloud)
DATABASE_PROVIDER=postgres

# PostgreSQL (cloud deployment - REQUIRED for production)
DATABASE_URL=postgresql://user:password@host:port/database

# Session Store Configuration
# Switch between 'memory' (local) and 'redis' (cloud)
SESSION_PROVIDER=redis

# Redis (cloud deployment - REQUIRED for production)
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=1800

# Application Configuration
FLASK_ENV=production
FLASK_DEBUG=0
PORT=5000

# Async Crawl Configuration (Phase 5)
# Set to 'true' to enable async background job crawling
USE_ASYNC_CRAWL=true

# Number of concurrent worker threads for crawling
# Low volume: 2, Medium: 3 (default), High volume: 5
CRAWL_WORKER_THREADS=3
