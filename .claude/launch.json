{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "$PORT", "-d", "frontend"],
      "port": 3001,
      "autoPort": true
    },
    {
      "name": "backend",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd backend && python3 app.py"],
      "port": 5000
    }
  ]
}
